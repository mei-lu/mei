---
import Stamp from "../templates/components/stamp.astro"
import Layout from "../templates/layouts/layout.astro"
import "../styles/pages/portfolio.css"
import CatRoom from "../assets/projects/cat-room.mp4"
import DesignSystem from "../assets/projects/design-system.webp"
import ScribbleHero from "../assets/projects/scribblehero.mp4"
---

<Layout title="mei" js="/scripts/app.ts">
    <div id="portfolio">
        <div class="portfolio-grid lock">
            <h1 class="sr-only">Portfolio</h1>
            <Stamp
                title="3D Cat Room"
                tags={["Web", "Three.js", "Blender"]}
                description="A cute room with interactive objects in the browser"
                video={CatRoom}
                links={{
                    Demo: "https://3d-cat-room.meilu.dev/",
                    Blog: "/garden/3d-room-blender-threejs",
                    GitHub: "",
                }}
            />

            <Stamp
                title="ScribbleHero"
                tags={["AR", "Snap Spectacles"]}
                description="Players sketches are classified and used as tools to fight fires in AR. Won Honorable Mention for Game Prototyping at MIT Reality Hack 2026!"
                video={ScribbleHero}
                links={{
                    // Demo: "/",
                    // Blog: "/portfolio-site",
                    GitHub: "https://github.com/mei-lu/ScribbleHero",
                }}
            />

            <Stamp
                title="University of Maryland Design System"
                tags={["JS Library", "Web Components"]}
                description="Created components and maintained library for a unified UMD brand."
                image={DesignSystem.src}
                links={{
                    Demo: "https://designsystem.umd.edu/components",
                    GitHub: "https://github.com/UMD-Digital/design-system",
                }}
            />
        </div>
    </div>
</Layout>

